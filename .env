# Host paths — change these when moving to a new drive
DATA_ROOT=/srv/data
CONFIG_ROOT=./config

# Shared group ID — all service users belong to this group
# Run ./setup.sh to create users/group and populate these values
PGID=1001
UMASK=002

# Per-service user IDs
PUID_JELLYFIN=999
PUID_SONARR=996
PUID_RADARR=995
PUID_PROWLARR=994
PUID_QBITTORRENT=993
PUID_BAZARR=990

# Timezone
TZ=Pacific/Auckland

# Caddy / Cloudflare
DOMAIN=office-computer-online-worldwide.org

# LAN IP — Pi-hole binds DNS here, router uses this as the DNS server
LAN_IP=192.168.1.33
