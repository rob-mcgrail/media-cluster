# Container config directories (contain runtime state, API keys, databases)
config/

# API keys for service access
.api_keys

# Movie Bot runtime data (inbox, completed requests, completed triage runs)
movie-bot-data/pending/*
!movie-bot-data/pending/.gitkeep
movie-bot-data/completed-requests/*
!movie-bot-data/completed-requests/.gitkeep
movie-bot-data/completed-triage-runs/*
!movie-bot-data/completed-triage-runs/.gitkeep
movie-bot-data/.*.lock

# Exported settings are safe to commit
!settings/

# Recs
recs.md
movie-bot-data/recommendations.jsonl
movie-bot-data/movie-thoughts.jsonl
movie-bot-data/completed-recs-runs/*
!movie-bot-data/completed-recs-runs/.gitkeep

# Double Features bot (active, dismissed, run reports)
movie-bot-data/double-features/*
!movie-bot-data/double-features/.gitkeep
movie-bot-data/dismissed-double-features/*
!movie-bot-data/dismissed-double-features/.gitkeep
movie-bot-data/completed-double-feature-runs/*
!movie-bot-data/completed-double-feature-runs/.gitkeep

# Library sweep logs (missing/cutoff cron)
movie-bot-data/sweep-logs/*
!movie-bot-data/sweep-logs/.gitkeep

# Python bytecode (e.g. tracker-watch syntax checks)
__pycache__/
*.pyc
